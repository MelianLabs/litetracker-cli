#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
BASE_URL="https://app.litetracker.com/services/v5"
CONFIG_DIR="$HOME/.lt"
TOKEN_FILE="$CONFIG_DIR/api_token"

# --- Helpers ---

die() {
  echo "Error: $1" >&2
  exit 1
}

check_deps() {
  command -v curl >/dev/null 2>&1 || die "curl is required. Install it with: sudo apt install curl"
  command -v jq >/dev/null 2>&1 || die "jq is required. Install it with: sudo apt install jq"
}

load_token() {
  [[ -f "$TOKEN_FILE" ]] || die "Not authenticated. Run 'lt auth' first."
  TOKEN=$(<"$TOKEN_FILE")
  [[ -n "$TOKEN" ]] || die "API token is empty. Run 'lt auth' to reconfigure."
}

api_get() {
  local response http_code body
  response=$(curl -sS -w "\n%{http_code}" -H "X-TrackerToken: $TOKEN" "$BASE_URL$1")
  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')
  if [[ "$http_code" -ge 400 ]]; then
    die "API error ($http_code): $body"
  fi
  echo "$body"
}

api_post() {
  local response http_code body
  response=$(curl -sS -w "\n%{http_code}" \
    -X POST \
    -H "X-TrackerToken: $TOKEN" \
    -H "Content-Type: application/json" \
    -d "$2" \
    "$BASE_URL$1")
  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')
  if [[ "$http_code" -ge 400 ]]; then
    die "API error ($http_code): $body"
  fi
  echo "$body"
}

api_put() {
  local response http_code body
  response=$(curl -sS -w "\n%{http_code}" \
    -X PUT \
    -H "X-TrackerToken: $TOKEN" \
    -H "Content-Type: application/json" \
    -d "$2" \
    "$BASE_URL$1")
  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')
  if [[ "$http_code" -ge 400 ]]; then
    die "API error ($http_code): $body"
  fi
  echo "$body"
}

# --- Commands ---

cmd_auth() {
  echo "Enter your LiteTracker API token."
  echo "You can find it at: https://app.litetracker.com/edit"
  echo ""
  read -rp "API Token: " token
  [[ -n "$token" ]] || die "Token cannot be empty."

  mkdir -p "$CONFIG_DIR"
  echo "$token" > "$TOKEN_FILE"
  chmod 600 "$TOKEN_FILE"

  # Verify token works
  TOKEN="$token"
  local me
  me=$(api_get "/me") || die "Token verification failed. Check your token and try again."
  local name
  name=$(echo "$me" | jq -r '.name // "Unknown"')
  echo "Authenticated as: $name"
  echo "Token saved to $TOKEN_FILE"
}

cmd_me() {
  local data
  data=$(api_get "/me")
  echo "$data" | jq '{
    id,
    name,
    initials,
    username,
    email,
    accounts: [.accounts[] | {name, status, plan}],
    projects: [.projects[] | {project_id, project_name, role}]
  }'
}

cmd_projects() {
  local data
  data=$(api_get "/projects")
  (
    echo -e "ID\tTITLE"
    echo "$data" | jq -r '.[] | [(.id|tostring), .title] | @tsv'
  ) | column -ts $'\t'
}

cmd_stories() {
  local project_id="${1:?Usage: lt stories <project_id>}"
  local data
  data=$(api_get "/projects/$project_id/stories")
  (
    echo -e "ID\tTYPE\tSTATE\tTITLE"
    echo "$data" | jq -r '.[] | [(.id|tostring), .story_type, .current_state, .title] | @tsv'
  ) | column -ts $'\t'
}

cmd_story_show() {
  local project_id="${1:?Usage: lt story show <project_id> <story_id>}"
  local story_id="${2:?Usage: lt story show <project_id> <story_id>}"
  local data
  data=$(api_get "/projects/$project_id/stories/$story_id")
  echo "$data" | jq '{
    id,
    title,
    description,
    story_type,
    current_state,
    estimate,
    owner_ids: [.owners[]?.user_id],
    url,
    labels: [.labels[]?.name],
    created_at,
    updated_at
  }'
}

cmd_story_create() {
  local project_id="${1:?Usage: lt story create <project_id> --name \"...\"}"
  shift
  local name="" story_type="feature" estimate="" label="" description=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)        name="${2:?--name requires a value}"; shift 2 ;;
      --type)        story_type="${2:?--type requires a value}"; shift 2 ;;
      --estimate)    estimate="${2:?--estimate requires a value}"; shift 2 ;;
      --label)       label="${2:?--label requires a value}"; shift 2 ;;
      --description) description="${2:?--description requires a value}"; shift 2 ;;
      *)             die "Unknown flag: $1" ;;
    esac
  done
  [[ -n "$name" ]] || die "--name is required"

  local json
  json=$(jq -n --arg name "$name" --arg type "$story_type" '{name: $name, story_type: $type}')
  [[ -n "$estimate" ]] && json=$(echo "$json" | jq --argjson est "$estimate" '. + {estimate: $est}')
  [[ -n "$label" ]] && json=$(echo "$json" | jq --arg lbl "$label" '. + {labels: [{name: $lbl}]}')
  [[ -n "$description" ]] && json=$(echo "$json" | jq --arg desc "$description" '. + {description: $desc}')

  local result
  result=$(api_post "/projects/$project_id/stories/" "$json")
  local new_id
  new_id=$(echo "$result" | jq -r '.id')
  echo "Created story #$new_id"
  echo "$result" | jq '{id, title, story_type, current_state, url}'
}

cmd_story_update() {
  local project_id="${1:?Usage: lt story update <project_id> <story_id> [flags]}"
  local story_id="${2:?Usage: lt story update <project_id> <story_id> [flags]}"
  shift 2
  local state="" estimate="" owner_ids=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --state)      state="${2:?--state requires a value}"; shift 2 ;;
      --estimate)   estimate="${2:?--estimate requires a value}"; shift 2 ;;
      --owner-ids)  owner_ids="${2:?--owner-ids requires a value}"; shift 2 ;;
      *)            die "Unknown flag: $1" ;;
    esac
  done
  [[ -n "$state" || -n "$estimate" || -n "$owner_ids" ]] || die "At least one of --state, --estimate, or --owner-ids is required"

  local json
  json=$(jq -n '{}')
  [[ -n "$state" ]] && json=$(echo "$json" | jq --arg s "$state" '. + {current_state: $s}')
  [[ -n "$estimate" ]] && json=$(echo "$json" | jq --argjson e "$estimate" '. + {estimate: $e}')
  [[ -n "$owner_ids" ]] && json=$(echo "$json" | jq --argjson ids "[$owner_ids]" '. + {owner_ids: $ids}')

  local result
  result=$(api_put "/projects/$project_id/stories/$story_id" "$json")
  echo "Updated story #$story_id"
  echo "$result" | jq '{id, title, story_type, current_state, estimate, owner_ids: [.owners[]?.user_id], url}'
}

cmd_story_label() {
  local project_id="${1:?Usage: lt story label <project_id> <story_id> --label \"...\"}"
  local story_id="${2:?Usage: lt story label <project_id> <story_id> --label \"...\"}"
  shift 2
  local label=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --label) label="${2:?--label requires a value}"; shift 2 ;;
      *)       die "Unknown flag: $1" ;;
    esac
  done
  [[ -n "$label" ]] || die "--label is required"

  local json
  json=$(jq -n --arg lbl "$label" '{label: {name: $lbl}}')
  local result
  result=$(api_post "/projects/$project_id/stories/$story_id/labels" "$json")
  echo "Added label '$label' to story #$story_id"
}

cmd_story_comments() {
  local project_id="${1:?Usage: lt story comments <project_id> <story_id>}"
  local story_id="${2:?Usage: lt story comments <project_id> <story_id>}"
  local data
  data=$(api_get "/projects/$project_id/stories/$story_id/comments")
  local count
  count=$(echo "$data" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    echo "No comments on story #$story_id"
    return
  fi
  echo "$data" | jq -r '.[] | "--- Comment #\(.id) at \(.created_at) ---\n\(.text)\n"'
}

cmd_story_comment() {
  local project_id="${1:?Usage: lt story comment <project_id> <story_id> --text \"...\"}"
  local story_id="${2:?Usage: lt story comment <project_id> <story_id> --text \"...\"}"
  shift 2
  local text=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --text) text="${2:?--text requires a value}"; shift 2 ;;
      *)      die "Unknown flag: $1" ;;
    esac
  done
  [[ -n "$text" ]] || die "--text is required"

  local json
  json=$(jq -n --arg t "$text" '{text: $t}')
  local result
  result=$(api_post "/projects/$project_id/stories/$story_id/comments" "$json")
  echo "Comment added to story #$story_id"
}

cmd_schema() {
  local path="${1:-}"
  if [[ -z "$path" ]]; then
    cat <<'LIST'
lt schema — Show API endpoint details

Usage:
  lt schema <endpoint>

Available endpoints:
  me                    GET /me
  projects.list         GET /projects
  stories.list          GET /projects/{project_id}/stories
  stories.get           GET /projects/{project_id}/stories/{story_id}
  stories.create        POST /projects/{project_id}/stories
  stories.update        PUT /projects/{project_id}/stories/{story_id}
  stories.comments.list GET /projects/{project_id}/stories/{story_id}/comments
  stories.comments.create POST /projects/{project_id}/stories/{story_id}/comments
  stories.labels.create POST /projects/{project_id}/stories/{story_id}/labels

Example:
  lt schema stories.create
LIST
    return
  fi

  local schema
  case "$path" in
    me)
      schema=$(jq -n '{
        description: "Returns information about the authenticated user.",
        httpMethod: "GET",
        path: "/me",
        auth: "X-TrackerToken header (required)",
        parameters: {},
        response: {
          properties: {
            id: {type: "string", description: "User ID"},
            name: {type: "string", description: "Full name"},
            initials: {type: "string", description: "User initials"},
            username: {type: "string", description: "Username"},
            email: {type: "string", description: "Email address"},
            accounts: {type: "array", description: "List of accounts with name, status, plan"},
            projects: {type: "array", description: "List of projects with project_id, project_name, role"}
          }
        }
      }') ;;
    projects|projects.list)
      schema=$(jq -n '{
        description: "Lists all projects accessible to the authenticated user.",
        httpMethod: "GET",
        path: "/projects",
        auth: "X-TrackerToken header (required)",
        parameters: {},
        response: {
          type: "array",
          items: {
            properties: {
              id: {type: "string", description: "Project ID"},
              title: {type: "string", description: "Project title"},
              created_at: {type: "string", description: "Creation timestamp"},
              updated_at: {type: "string", description: "Last update timestamp"}
            }
          }
        }
      }') ;;
    stories.list)
      schema=$(jq -n '{
        description: "Lists all stories in a project.",
        httpMethod: "GET",
        path: "/projects/{project_id}/stories",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"}
        },
        response: {
          type: "array",
          items: {
            properties: {
              id: {type: "string", description: "Story ID"},
              title: {type: "string", description: "Story title"},
              story_type: {type: "string", description: "Type: feature, bug, or chore"},
              current_state: {type: "string", description: "State: unscheduled, unstarted, started, finished, delivered, accepted, rejected"},
              estimate: {type: "integer", description: "Point estimate"},
              labels: {type: "array", description: "Array of label objects with name field"},
              owner_ids: {type: "array", description: "Array of user IDs who own the story"},
              created_at: {type: "string", description: "Creation timestamp"},
              updated_at: {type: "string", description: "Last update timestamp"},
              url: {type: "string", description: "Web URL for the story"}
            }
          }
        }
      }') ;;
    stories.get)
      schema=$(jq -n '{
        description: "Returns details for a single story.",
        httpMethod: "GET",
        path: "/projects/{project_id}/stories/{story_id}",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"},
          story_id: {type: "string", location: "path", required: true, description: "Story ID"}
        },
        response: {
          properties: {
            id: {type: "string", description: "Story ID"},
            title: {type: "string", description: "Story title"},
            story_type: {type: "string", description: "Type: feature, bug, or chore"},
            current_state: {type: "string", description: "State: unscheduled, unstarted, started, finished, delivered, accepted, rejected"},
            estimate: {type: "integer", description: "Point estimate"},
            labels: {type: "array", description: "Array of label objects with name field"},
            owner_ids: {type: "array", description: "Array of user IDs who own the story"},
            description: {type: "string", description: "Story description"},
            created_at: {type: "string", description: "Creation timestamp"},
            updated_at: {type: "string", description: "Last update timestamp"},
            url: {type: "string", description: "Web URL for the story"}
          }
        }
      }') ;;
    stories.create)
      schema=$(jq -n '{
        description: "Creates a new story in a project. Note: LiteTracker accepts \"name\" for the title field on create, but returns \"title\" in responses.",
        httpMethod: "POST",
        path: "/projects/{project_id}/stories",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"}
        },
        requestBody: {
          properties: {
            name: {type: "string", required: true, description: "Story title (required)"},
            story_type: {type: "string", required: false, description: "Type: feature (default), bug, or chore"},
            estimate: {type: "integer", required: false, description: "Point estimate"},
            description: {type: "string", required: false, description: "Story description"},
            labels: {type: "array", required: false, description: "Array of label objects, e.g. [{\"name\": \"urgent\"}]"}
          }
        },
        notes: [
          "owner_ids is ignored on create — use story update to assign owners"
        ],
        response: {
          properties: {
            id: {type: "string", description: "Created story ID"},
            title: {type: "string", description: "Story title"},
            story_type: {type: "string", description: "Story type"},
            current_state: {type: "string", description: "Initial state"},
            url: {type: "string", description: "Web URL for the story"}
          }
        }
      }') ;;
    stories.update)
      schema=$(jq -n '{
        description: "Updates a story'\''s estimate, state, and/or owners. All parameters are optional — include only what you want to change.",
        httpMethod: "PUT",
        path: "/projects/{project_id}/stories/{story_id}",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"},
          story_id: {type: "string", location: "path", required: true, description: "Story ID"}
        },
        requestBody: {
          properties: {
            current_state: {type: "string", required: false, description: "State: unscheduled, unstarted, planned, started, finished, delivered, rejected, accepted"},
            estimate: {type: "integer", required: false, description: "Point estimate"},
            owner_ids: {type: "array", required: false, description: "Array of user IDs to assign as owners"}
          }
        },
        notes: [
          "State transitions follow AASM rules (e.g., cannot accept a story that has not been delivered)",
          "For chores and releases, finish automatically maps to accept",
          "Feature/bug stories require an estimate before starting (unless chores/releases)"
        ],
        response: {
          properties: {
            id: {type: "string", description: "Story ID"},
            title: {type: "string", description: "Story title"},
            story_type: {type: "string", description: "Story type"},
            current_state: {type: "string", description: "Updated state"},
            estimate: {type: "integer", description: "Point estimate"},
            owner_ids: {type: "array", description: "Updated array of user IDs assigned as owners"},
            url: {type: "string", description: "Web URL for the story"}
          }
        }
      }') ;;
    stories.comments|stories.comments.list)
      schema=$(jq -n '{
        description: "Lists all comments on a story.",
        httpMethod: "GET",
        path: "/projects/{project_id}/stories/{story_id}/comments",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"},
          story_id: {type: "string", location: "path", required: true, description: "Story ID"}
        },
        response: {
          type: "array",
          items: {
            properties: {
              id: {type: "string", description: "Comment ID"},
              text: {type: "string", description: "Comment text"},
              person_id: {type: "string", description: "ID of the commenter"},
              story_id: {type: "string", description: "Parent story ID"},
              created_at: {type: "string", description: "Creation timestamp"},
              updated_at: {type: "string", description: "Last update timestamp"}
            }
          }
        }
      }') ;;
    stories.comments.create)
      schema=$(jq -n '{
        description: "Adds a comment to a story.",
        httpMethod: "POST",
        path: "/projects/{project_id}/stories/{story_id}/comments",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"},
          story_id: {type: "string", location: "path", required: true, description: "Story ID"}
        },
        requestBody: {
          properties: {
            text: {type: "string", required: true, description: "Comment text (required)"}
          }
        },
        response: {
          properties: {
            id: {type: "string", description: "Comment ID"},
            text: {type: "string", description: "Comment text"},
            person_id: {type: "string", description: "ID of the commenter"},
            created_at: {type: "string", description: "Creation timestamp"}
          }
        }
      }') ;;
    stories.labels|stories.labels.create)
      schema=$(jq -n '{
        description: "Adds a label to a story.",
        httpMethod: "POST",
        path: "/projects/{project_id}/stories/{story_id}/labels",
        auth: "X-TrackerToken header (required)",
        parameters: {
          project_id: {type: "string", location: "path", required: true, description: "Project ID"},
          story_id: {type: "string", location: "path", required: true, description: "Story ID"}
        },
        requestBody: {
          properties: {
            label: {type: "object", required: true, description: "Label object with name field, e.g. {\"label\": {\"name\": \"urgent\"}}"}
          }
        },
        response: {
          properties: {
            id: {type: "string", description: "Label ID"},
            name: {type: "string", description: "Label name"}
          }
        }
      }') ;;
    *)
      die "Unknown schema: $path. Run 'lt schema' to see available endpoints." ;;
  esac

  echo "$schema"
}

cmd_help() {
  cat <<'HELP'
lt - LiteTracker CLI

Usage:
  lt <command> [arguments]

Commands:
  auth                                          Configure API token
  me                                            Show current user details
  projects                                      List all projects
  stories <project_id>                          List stories in a project
  story show <project_id> <story_id>            Show story details
  story create <project_id> [flags]             Create a new story
  story update <project_id> <story_id> [flags]  Update a story
  story label <project_id> <story_id> [flags]   Add a label to a story
  story comments <project_id> <story_id>          List comments on a story
  story comment <project_id> <story_id> [flags]   Add a comment
  schema [endpoint]                               Show API endpoint details
  help                                          Show this help
  version                                       Show version

Story Create Flags:
  --name "..."         Story name (required)
  --type TYPE          feature, bug, or chore (default: feature)
  --estimate N         Point estimate
  --label "..."        Add a label
  --description "..."  Story description

Story Update Flags:
  --state STATE      State: unscheduled, unstarted, planned, started, finished, delivered, rejected, accepted
  --estimate N       Point estimate
  --owner-ids N,...  Comma-separated user IDs

Story Label Flags:
  --label "..."      Label name (required)

Story Comment Flags:
  --text "..."       Comment text (required)

Setup:
  1. Get your API token from https://app.litetracker.com/edit
  2. Run: lt auth

HELP
}

cmd_version() {
  echo "lt version $VERSION"
}

# --- Main Router ---

main() {
  check_deps

  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    auth)     cmd_auth "$@" ;;
    me)       load_token; cmd_me "$@" ;;
    projects) load_token; cmd_projects "$@" ;;
    stories)  load_token; cmd_stories "$@" ;;
    story)
      load_token
      local action="${1:-help}"
      shift || true
      case "$action" in
        show)    cmd_story_show "$@" ;;
        create)  cmd_story_create "$@" ;;
        update)  cmd_story_update "$@" ;;
        label)   cmd_story_label "$@" ;;
        comments) cmd_story_comments "$@" ;;
        comment)  cmd_story_comment "$@" ;;
        *)        die "Unknown story action: $action. Use: show, create, update, label, comments, comment" ;;
      esac
      ;;
    schema)   cmd_schema "$@" ;;
    help|-h|--help) cmd_help ;;
    version|--version|-v) cmd_version ;;
    *) die "Unknown command: $cmd. Run 'lt help' for usage." ;;
  esac
}

main "$@"
